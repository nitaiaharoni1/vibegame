{
  "name": "@vigame/mcp",
  "version": "0.1.0",
  "description": "MCP server — gives AI agents live control of running Three.js/Phaser games",
  "type": "module",
  "bin": {
    "vigame-mcp": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@vigame/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nitaiaharoni1/vibegame.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/nitaiaharoni1/vibegame#readme",
  "publishConfig": {
    "access": "public"
  }
}
